# MATRIX-NEO 設定例（コピーして .env として使う場合は python-dotenv 等が別途必要）
# 詳細は README.md の環境変数表を参照

MATRIX_NEO_PORT=6850
MATRIX_NEO_LOG_LEVEL=INFO
MATRIX_NEO_BLOCK_PRIVATE_IPS=0
MATRIX_NEO_TASK_TTL_HOURS=24
MATRIX_NEO_TASK_GC_INTERVAL_SEC=300

MAX_CONCURRENT_DOWNLOADS=10
MATRIX_NEO_M3U8_THREADS=32
MATRIX_NEO_M3U8_RETRY=50
MATRIX_NEO_M3U8_HTTP_TIMEOUT=120
MATRIX_NEO_M3U8_MT=1
MATRIX_NEO_M3U8_MAX_SPEED=
MATRIX_NEO_M3U8_STALL_SEC=120
MATRIX_NEO_M3U8_RETRY_NO_MT_ON_STALL=1
MATRIX_NEO_M3U8_BROWSER_HEADERS=1
MATRIX_NEO_M3U8_USER_AGENT=
MATRIX_NEO_M3U8_MUX_TS=1
