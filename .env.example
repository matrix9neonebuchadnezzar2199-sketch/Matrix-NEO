# MATRIX-NEO 設定例（このファイルを .env にリネームすると起動時に自動読込されます）
# 詳細は README.md の環境変数表を参照

MATRIX_NEO_PORT=6850
MATRIX_NEO_LOG_LEVEL=INFO
MATRIX_NEO_BLOCK_PRIVATE_IPS=0
MATRIX_NEO_PROXY_IMAGE_RATE_LIMIT=30
MATRIX_NEO_PROXY_IMAGE_RATE_WINDOW_SEC=60
# カンマ区切り（既定は VPN らしい ASN 名のヒューリスティック）
# MATRIX_NEO_VPN_KEYWORDS=vpn,nord,express,...
MATRIX_NEO_TASK_TTL_HOURS=24
MATRIX_NEO_TASK_GC_INTERVAL_SEC=300

# --- Authentication ---
# Bearer トークンを設定すると /health 以外のエンドポイントに認証が必須になります。
# 空のままなら認証なし（後方互換）。
# MATRIX_NEO_AUTH_TOKEN=your-secret-token-here
# AUTO=1 にすると起動時にトークンを自動生成しログに表示します。
# MATRIX_NEO_AUTH_TOKEN_AUTO=0

# --- Thumbnail ---
# サムネイル埋め込み並列ワーカー数（既定: 2）
MATRIX_NEO_THUMB_WORKERS=2

# --- Disk space ---
# ダウンロード開始前の最低空きディスク容量 (MB)。不足時はエラーで停止。
MATRIX_NEO_MIN_FREE_DISK_MB=500

MAX_CONCURRENT_DOWNLOADS=10
MATRIX_NEO_M3U8_THREADS=32
MATRIX_NEO_M3U8_RETRY=50
MATRIX_NEO_M3U8_HTTP_TIMEOUT=120
MATRIX_NEO_M3U8_MT=1
MATRIX_NEO_M3U8_MAX_SPEED=
MATRIX_NEO_M3U8_STALL_SEC=120
MATRIX_NEO_M3U8_RETRY_NO_MT_ON_STALL=1
MATRIX_NEO_M3U8_BROWSER_HEADERS=1
MATRIX_NEO_M3U8_USER_AGENT=
MATRIX_NEO_M3U8_MUX_TS=1
