Windows Registry Editor Version 5.00

; MATRIX-NEO: 拡張の「サーバー起動」ボタン用
; フォルダを移動したら extension ではなく、プロジェクト直下の install-server-protocol.bat を実行してください。

[HKEY_CURRENT_USER\Software\Classes\matrixneo]
@="URL:MATRIX NEO Server"
"URL Protocol"=""

[HKEY_CURRENT_USER\Software\Classes\matrixneo\shell\open\command]
@="cmd.exe /c start \"MATRIX NEO Server\" cmd.exe /k \"H:\\CURSOR\\MATRIX-NEO\\start_server_terminal.bat\""
